# ── Environment ─────────────────────────────────────────────────────────────
ENV=dev
LOG_LEVEL=INFO
LOG_FORMAT=pretty            # "json" in prod, "pretty" in dev
LOG_PII=false                # if true, message text appears in logs

# ── Telegram ────────────────────────────────────────────────────────────────
# Get a token from @BotFather in Telegram.
TELEGRAM_BOT_TOKEN=

# Random secret string. Telegram echoes it in X-Telegram-Bot-Api-Secret-Token.
# Generate: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# Public HTTPS URL of your webhook, e.g. https://yourdomain.dev/webhooks/telegram
# In dev, paste the ngrok URL here before running `make register-webhook`.
TELEGRAM_WEBHOOK_URL=

# Comma-separated list of Telegram user IDs allowed to talk to the bot.
# Find yours by messaging @userinfobot.
ALLOWED_TELEGRAM_USER_IDS=

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Postgres ────────────────────────────────────────────────────────────────
POSTGRES_DSN=postgresql+asyncpg://jarvis:jarvis@postgres:5432/jarvis

# ── Caddy (prod only) ───────────────────────────────────────────────────────
DOMAIN=yourdomain.dev
